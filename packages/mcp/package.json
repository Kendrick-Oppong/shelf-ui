{
  "name": "@shelf-ui/mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol (MCP) server for Shelf UI components",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "shelf-ui-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
