{
  "name": "@shelf-ui/mcp",
  "version": "0.2.0",
  "description": "Model Context Protocol (MCP) server for Shelf UI – search components, get install commands, and fetch component schemas from the Shelf UI registry.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "shelf-ui-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "shelf-ui",
    "shadcn",
    "ui-components",
    "ai",
    "llm",
    "cursor",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Kendrick-Oppong/shelf-ui.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://shelf-ui.vercel.app",
  "bugs": {
    "url": "https://github.com/Kendrick-Oppong/shelf-ui/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  }
}
