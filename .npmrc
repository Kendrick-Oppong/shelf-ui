# Use pnpm-specific peer dep handling instead
# legacy-peer-deps and strict-peer-deps are npm-only flags — pnpm ignores them
# pnpm uses its own peer dep config:
auto-install-peers=true
strict-peer-dependencies=false

# Keep these — they work in pnpm too
prefer-offline=true
save-exact=true
fund=false
engine-strict=true

# pnpm-specific: don't hoist everything to root node_modules
shamefully-hoist=false

# pnpm-specific: link workspace packages
link-workspace-packages=true
